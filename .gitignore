# =============================================================================
# FloraMate · Git Ignore 规则
# =============================================================================
# 仅排除：编译产物 / IDE 缓存 / 临时文件
# 保留：源码 / 设计文档 / 厂家原始资料（file/、old_file/ 下的 hex/uvproj 等）
# =============================================================================

# -----------------------------------------------------------------------------
# CubeIDE / Eclipse 编译产物（每次编译重新生成，几十 MB）
# -----------------------------------------------------------------------------
code/Debug/
code/Release/
code/build/
code/cmake-build-*/

# Eclipse / CubeIDE 工作区缓存（平台相关、跨机不兼容）
code/.metadata/
code/RemoteSystemsTempFiles/
*.launch

# -----------------------------------------------------------------------------
# 标准 C/C++ 编译产物（仅作兜底；厂家资料目录里同名文件由路径规则白名单保留）
# -----------------------------------------------------------------------------
# code/ 下的中间产物
code/**/*.o
code/**/*.obj
code/**/*.d
code/**/*.elf
code/**/*.map
code/**/*.bin
code/**/*.hex
code/**/*.lst
code/**/*.su
code/**/*.cyclo
code/**/*.axf

# 静态库 / 调试符号
*.a
*.lib
*.pdb
*.dSYM/

# -----------------------------------------------------------------------------
# Keil µVision 临时文件（厂家资料目录里的 .uvproj 等正式文件保留）
# -----------------------------------------------------------------------------
*.uvgui_*
*.uvgui.*
*.uvopt.bak
*.uvproj.bak
*_uvopt.bak
*_uvproj.bak
*.bak
*.dep
*.crf
*.lnp
*.htm

# Keil 输出目录常见名
**/Listings/
**/Objects/
**/Output/
**/Debug_Output/

# JLink / ST-Link 日志
JLinkLog.txt
**/JLinkLog.txt
*.jlink
*.svd.bak

# -----------------------------------------------------------------------------
# 编辑器临时文件 / 备份
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo
*~
.#*
\#*\#
*.orig
*.rej

# -----------------------------------------------------------------------------
# 操作系统垃圾
# -----------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# 厂家资料目录里的运行时垃圾
# -----------------------------------------------------------------------------
# 厂家资料目录里的 hex/uvproj/uvopt 是参考性资料，保留
# 但运行时生成的 *.bak / JLinkLog.txt / *.uvgui_* 已被上面通配规则排除

# -----------------------------------------------------------------------------
# 编辑器/工具配置（保留 .vscode/settings.json 因为它包含项目本地配置；
#                如团队多人开发想 ignore，注释掉下方"!" 即可）
# -----------------------------------------------------------------------------
.idea/
.vs/
*.code-workspace

# 保留 .vscode/settings.json（项目本地约定）
# 但忽略 .vscode/ 其它噪音
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# Python / 脚本产物（如果项目里有 build 脚本）
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# -----------------------------------------------------------------------------
# 其它工具临时文件
# -----------------------------------------------------------------------------
*.log
*.tlog
*.cache
